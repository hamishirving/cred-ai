# ===========================================
# Supabase (Database & Auth)
# ===========================================

# Get from Project Settings → Database (use the pooler connection string)
DATABASE_URL=postgresql://user:password@host:6543/database

# Get from Project Settings → API
# Required for authentication
NEXT_PUBLIC_SUPABASE_URL=https://****supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=****

# ===========================================
# AI Provider (Anthropic)
# ===========================================

# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-****

# ===========================================
# Ragie (Knowledge Retrieval)
# ===========================================

# Get from Ragie dashboard
RAGIE_API_KEY=****

# Ragie partition used when an org can't be mapped.
# UK is typically "default"; US is "usa".
RAGIE_DEFAULT_PARTITION=default

# Optional explicit org ID -> partition mapping (comma-separated).
# Format: orgId:partition,orgId:partition
RAGIE_ORG_PARTITION_MAP=

# Optional org slug -> partition mapping (comma-separated).
# Format: slug:partition,slug:partition
RAGIE_ORG_SLUG_PARTITION_MAP=

# ===========================================
# Credentially API
# ===========================================

CREDENTIALLY_API_URL=https://dev-eu-london.drfocused.com/gateway
CREDENTIALLY_API_KEY=****

# ===========================================
# Security & Email Verification
# ===========================================

# Email Domain Whitelist (comma-separated, empty = allow all)
ALLOWED_EMAIL_DOMAINS=credentially.io,credentially.com

# Site URL for email verification redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# First Advantage / Sterling API
# ===========================================

FA_API_MODE=mock
FA_CLIENT_ID=
FA_CLIENT_SECRET=
FA_API_BASE_URL=https://api.us.int.sterlingcheck.app/v2

# ===========================================
# Twilio (SMS)
# ===========================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional demo/testing override: force all outbound SMS to this number.
# Use E.164 format, e.g. +447780781414
# SMS_TEST_OVERRIDE_TO=
# Optional alternative sender configuration:
# TWILIO_MESSAGING_SERVICE_SID=
# Optional for inbound webhook signature validation:
# TWILIO_WEBHOOK_AUTH_TOKEN=
